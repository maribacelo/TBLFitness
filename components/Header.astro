---
// src/components/Header.astro
---

<header class="header" id="header" role="banner">
  <div class="container header__inner">

    <!-- Logo -->
    <a href="#inicio" class="header__logo" aria-label="TBL Studio – Bernardo Lima">
      <img src={`${import.meta.env.BASE_URL}images/logo_tbl.jpg`} alt="TBL Train Beyond Your Limits" class="header__logo-img" width="36" height="36" />
      <span class="logo-text">
        <strong>Bernardo</strong>
        <em>Personal Training</em>
      </span>
    </a>

    <!-- Nav desktop -->
    <nav class="header__nav" aria-label="Navegação principal">
      <ul role="list">
        <li><a href="#formatos">Formatos</a></li>
        <li><a href="#especialidades">Especialidades</a></li>
        <li><a href="#como-funciona">Como funciona</a></li>
        <li><a href="#sobre">Sobre</a></li>
        <li><a href="#contacto">Contacto</a></li>
      </ul>
    </nav>

    <!-- Actions desktop -->
    <div class="header__actions">
      <a href="https://wa.me/351969698944" target="_blank" rel="noopener noreferrer" class="header__wa">
        💬 WhatsApp
      </a>
      <a
        href="https://wa.me/351969698944?text=Ol%C3%A1%20Bernardo%2C%20gostaria%20de%20marcar%20uma%20avalia%C3%A7%C3%A3o%20inicial."
        target="_blank"
        rel="noopener noreferrer"
        class="btn btn--primary btn--small"
      >Agendar avaliação</a>
    </div>

    <!-- Hamburger -->
    <button
      class="header__burger"
      id="menuToggle"
      aria-label="Abrir menu de navegação"
      aria-expanded="false"
      aria-controls="mobileMenu"
    >
      <span></span><span></span><span></span>
    </button>
  </div>

  <!-- Mobile menu -->
  <nav class="mobile-menu" id="mobileMenu" aria-hidden="true" aria-label="Menu mobile">
    <ul role="list">
      <li><a href="#formatos" class="mobile-menu__link">Formatos</a></li>
      <li><a href="#especialidades" class="mobile-menu__link">Especialidades</a></li>
      <li><a href="#como-funciona" class="mobile-menu__link">Como funciona</a></li>
      <li><a href="#sobre" class="mobile-menu__link">Sobre</a></li>
      <li><a href="#contacto" class="mobile-menu__link">Contacto</a></li>
      <li>
        <a
          href="https://wa.me/351969698944?text=Ol%C3%A1%20Bernardo%2C%20gostaria%20de%20marcar%20uma%20avalia%C3%A7%C3%A3o%20inicial."
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn--primary mobile-menu__cta"
        >Agendar avaliação</a>
      </li>
    </ul>
  </nav>
</header>

<style>
.header {
  position: sticky;
  top: 0;
  z-index: 50;
  background: rgba(255,255,255,.97);
  border-bottom: 1px solid var(--borda);
  box-shadow: 0 2px 16px rgba(47,74,53,.07);
  backdrop-filter: blur(12px);
}
.header__inner {
  height: var(--header-h);
  display: flex;
  align-items: center;
  gap: 1.5rem;
}
.header__logo {
  display: flex;
  align-items: center;
  gap: .625rem;
  flex-shrink: 0;
  text-decoration: none;
}
.header__logo-img {
  width: 36px;
  height: 36px;
  border-radius: 8px;
  object-fit: cover;
}
.logo-text {
  display: flex;
  flex-direction: column;
  line-height: 1.15;
}
.logo-text strong {
  font-size: .875rem;
  font-weight: 700;
  color: var(--verde-esc);
}
.logo-text em {
  font-size: .625rem;
  font-style: normal;
  color: var(--sec);
  letter-spacing: .04em;
}
.header__nav {
  display: none;
  flex: 1;
  justify-content: center;
}
.header__nav ul {
  display: flex;
  gap: .25rem;
}
.header__nav a {
  font-size: .84375rem;
  font-weight: 500;
  color: var(--texto);
  padding: .4375rem .8125rem;
  border-radius: var(--radius-sm);
  transition: color .15s, background .15s;
}
.header__nav a:hover {
  color: var(--verde);
  background: var(--verde-claro);
}
.header__actions {
  display: none;
  align-items: center;
  gap: .625rem;
  flex-shrink: 0;
}
.header__wa {
  font-size: .8125rem;
  font-weight: 600;
  color: #25D366;
  text-decoration: none;
}
.header__burger {
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 5px;
  padding: .5rem;
  margin-left: auto;
  min-width: 44px;
  min-height: 44px;
  border-radius: var(--radius-sm);
  transition: background .15s;
}
.header__burger:hover { background: var(--verde-claro); }
.header__burger span {
  display: block;
  width: 22px;
  height: 2px;
  background: var(--texto);
  border-radius: 2px;
  transition: transform .25s, opacity .25s;
  transform-origin: center;
}
.header__burger.active span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
.header__burger.active span:nth-child(2) { opacity: 0; transform: scaleX(0); }
.header__burger.active span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

/* Mobile menu */
.mobile-menu {
  display: none;
  background: #fff;
  border-top: 1px solid var(--borda);
  padding: .5rem 1.25rem 1rem;
}
.mobile-menu.open { display: block; }
.mobile-menu ul { display: flex; flex-direction: column; gap: .25rem; }
.mobile-menu__link {
  display: block;
  font-size: .9375rem;
  font-weight: 500;
  color: var(--texto);
  padding: .625rem .5rem;
  border-radius: var(--radius-sm);
  transition: color .15s, background .15s;
}
.mobile-menu__link:hover { color: var(--verde); background: var(--verde-claro); }
.mobile-menu__cta { margin-top: .75rem; width: 100%; }

@media (min-width: 768px) {
  .header__actions { display: flex; }
}
@media (min-width: 1024px) {
  .header__nav { display: flex; }
  .header__burger { display: none; }
}
</style>
