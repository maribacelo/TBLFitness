---
// src/layouts/BaseLayout.astro
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Personal Trainer no Areeiro | TBL Studio – Bernardo Lima',
  description = 'Treino personalizado no Areeiro, Lisboa. Personal Training presencial, online, app e empresas. Bernardo Lima, 13+ anos de experiência. Avaliação inicial disponível.',
} = Astro.props;

const site = 'https://maribacelo.github.io/TBLFitness'; // ← [SUBSTITUIR]
const ogImage = `${site}/images/foto_sessao_1.jpg`;
---

<!doctype html>
<html lang="pt-PT">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={site + '/'} />

    <!-- Google Search Console verification meta tag goes here -->

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={site + '/'} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="pt_PT" />
    <meta property="og:site_name" content="TBL Studio – Bernardo Lima" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <meta name="theme-color" content="#4A7A2E" />

    <!-- Favicon [SUBSTITUIR pelos ficheiros reais] -->
    <link rel="icon" type="image/png" href={`${import.meta.env.BASE_URL}images/logo_tbl.jpg`} />
    <link rel="apple-touch-icon" href={`${import.meta.env.BASE_URL}images/logo_tbl.jpg`} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;1,400&family=DM+Sans:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />

    <!-- JSON-LD -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "HealthAndBeautyBusiness",
        "name": "TBL Studio & Personal Training by Bernardo Lima",
        "description": "Serviço de personal training no Areeiro, Lisboa. Presencial, online, app, outdoor e empresas.",
        "url": "https://maribacelo.github.io/TBLFitness/",
        "image": "https://maribacelo.github.io/TBLFitness/images/foto_sessao_1.jpg",
        "telephone": "+351969698944",
        "email": "bernardo.lima93@gmail.com",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "Av. Almirante Gago Coutinho",
          "addressLocality": "Lisboa",
          "postalCode": "1000-015",
          "addressCountry": "PT"
        },
        "geo": {
          "@type": "GeoCoordinates",
          "latitude": "38.7389",
          "longitude": "-9.1305"
        },
        "areaServed": [
          { "@type": "City", "name": "Lisboa" },
          { "@type": "Neighborhood", "name": "Areeiro" }
        ],
        "openingHoursSpecification": [
          { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"], "opens": "07:00", "closes": "22:00" },
          { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Saturday","Sunday"], "opens": "08:00", "closes": "15:00" }
        ],
        "sameAs": ["https://www.instagram.com/tbl.treinos"]
      }
    </script>
  </head>

  <body>
    <a href="#main-content" class="skip-link">Saltar para o conteúdo</a>
    <slot />
    <a
      href="https://wa.me/351969698944?text=Ol%C3%A1%20Bernardo%2C%20gostaria%20de%20saber%20mais%20sobre%20os%20seus%20servi%C3%A7os."
      class="whatsapp-fab"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Falar pelo WhatsApp"
    >💬</a>
  </body>
</html>
