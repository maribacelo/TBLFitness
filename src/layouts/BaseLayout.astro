---
// src/layouts/BaseLayout.astro
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Personal Trainer no Areeiro, Lisboa | TBL Studio – Bernardo Lima',
  description = 'Treino personalizado no Areeiro, Lisboa. Personal Training presencial, online, app e empresas. Bernardo Lima, 13+ anos de experiência. Avaliação inicial disponível.',
} = Astro.props;

const site = 'https://tblstudio.pt';
const siteUrl = `${site}/`;
const assetBase = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const assetPath = (file: string) => `${assetBase}images/${file}`;
const absoluteImage = (file: string) => `${siteUrl}images/${file}`;
const ogImage = absoluteImage('foto_sessao_1.jpg');
const logoImage = assetPath('logo_tbl.jpg');
const canonicalUrl = siteUrl;
const businessId = `${siteUrl}#localbusiness`;
const websiteId = `${siteUrl}#website`;
const webpageId = `${siteUrl}#webpage`;
const personId = `${siteUrl}#bernardo-lima`;
const mapsUrl = 'https://www.google.com/maps/dir/?api=1&destination=Av.%20Alm.%20Gago%20Coutinho%2C%201000-015%20Lisboa%2C%20Portugal';
const structuredData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      '@id': websiteId,
      url: siteUrl,
      name: 'TBL Studio & Personal Training by Bernardo Lima',
      inLanguage: 'pt-PT',
      publisher: { '@id': businessId },
    },
    {
      '@type': 'WebPage',
      '@id': webpageId,
      url: siteUrl,
      name: title,
      description,
      inLanguage: 'pt-PT',
      isPartOf: { '@id': websiteId },
      about: { '@id': businessId },
      primaryImageOfPage: {
        '@type': 'ImageObject',
        url: ogImage,
        width: 900,
        height: 1200,
      },
    },
    {
      '@type': ['HealthClub', 'ExerciseGym'],
      '@id': businessId,
      name: 'TBL Studio & Personal Training by Bernardo Lima',
      alternateName: 'TBL Studio',
      description: 'Serviço de personal training no Areeiro, Lisboa. Presencial, online, app, outdoor e empresas.',
      url: siteUrl,
      logo: absoluteImage('logo_tbl.jpg'),
      image: [
        absoluteImage('foto_sessao_1.jpg'),
        absoluteImage('foto_espaco_1.jpg'),
        absoluteImage('foto_bernardo.jpg'),
      ],
      telephone: '+351969698944',
      email: 'tbl.treinos@gmail.com',
      address: {
        '@type': 'PostalAddress',
        streetAddress: 'Av. Alm. Gago Coutinho',
        addressLocality: 'Lisboa',
        postalCode: '1000-015',
        addressCountry: 'PT',
      },
      geo: {
        '@type': 'GeoCoordinates',
        latitude: 38.74464720458884,
        longitude: -9.13366005819632,
      },
      hasMap: mapsUrl,
      areaServed: [
        { '@type': 'City', name: 'Lisboa' },
        { '@type': 'Neighborhood', name: 'Areeiro' },
      ],
      openingHoursSpecification: [
        { '@type': 'OpeningHoursSpecification', dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'], opens: '07:00', closes: '22:00' },
        { '@type': 'OpeningHoursSpecification', dayOfWeek: ['Saturday', 'Sunday'], opens: '08:00', closes: '15:00' },
      ],
      hasOfferCatalog: {
        '@type': 'OfferCatalog',
        name: 'Formatos de treino',
        itemListElement: [
          { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Personal Training Presencial' } },
          { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Personal Training Online' } },
          { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Plano por App' } },
          { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Treino Outdoor' } },
          { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Ginástica Laboral' } },
        ],
      },
      founder: { '@id': personId },
      sameAs: ['https://www.instagram.com/tbl.treinos'],
    },
    {
      '@type': 'Person',
      '@id': personId,
      name: 'Bernardo Lima',
      jobTitle: 'Personal Trainer',
      image: absoluteImage('foto_bernardo.jpg'),
      worksFor: { '@id': businessId },
    },
  ],
};
---

<!doctype html>
<html lang="pt-PT">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Google Search Console verification meta tag goes here -->

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="900" />
    <meta property="og:image:height" content="1200" />
    <meta property="og:image:alt" content="Bernardo Lima a acompanhar uma sessão de treino personalizado no Areeiro, Lisboa" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="pt_PT" />
    <meta property="og:site_name" content="TBL Studio – Bernardo Lima" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content="Bernardo Lima a acompanhar uma sessão de treino personalizado no Areeiro, Lisboa" />

    <meta name="theme-color" content="#4A7A2E" />

    <link rel="icon" type="image/jpeg" href={logoImage} />
    <link rel="apple-touch-icon" href={logoImage} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;1,400&family=DM+Sans:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />

    <!-- JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
  </head>

  <body>
    <a href="#main-content" class="skip-link">Saltar para o conteúdo</a>
    <slot />
    <a
      href="https://wa.me/351969698944?text=Ol%C3%A1%20Bernardo%2C%20gostaria%20de%20saber%20mais%20sobre%20os%20seus%20servi%C3%A7os."
      class="whatsapp-fab"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Falar pelo WhatsApp"
    >💬</a>
  </body>
</html>
