---
interface Props {
  src: string;
  alt: string;
  width: number | string;
  height: number | string;
  loading?: 'eager' | 'lazy';
  decoding?: 'async' | 'sync' | 'auto';
  fetchpriority?: 'high' | 'low' | 'auto';
  class?: string;
}

const {
  src,
  alt,
  width,
  height,
  loading = 'lazy',
  decoding = 'async',
  fetchpriority,
  class: className,
} = Astro.props;

const webpSrc = src.replace(/\.jpe?g$/i, '.webp');
---

<picture class="optimized-picture">
  <source srcset={webpSrc} type="image/webp" />
  <img
    src={src}
    alt={alt}
    width={width}
    height={height}
    loading={loading}
    decoding={decoding}
    fetchpriority={fetchpriority}
    class={className}
  />
</picture>

<style>
.optimized-picture { display: contents; }
</style>
