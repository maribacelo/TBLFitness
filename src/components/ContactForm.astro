---
---

<form class="contact-form" data-contact-form novalidate>
  <p class="form-nota">Resposta nas 24 horas seguintes por WhatsApp ou email.</p>

  <div class="form-group">
    <label for="nome">Nome <span aria-hidden="true">*</span></label>
    <input
      type="text"
      id="nome"
      name="nome"
      placeholder="O seu nome"
      autocomplete="name"
      aria-invalid="false"
      data-field="nome"
    />
    <span id="erro-nome" class="form-erro" role="alert" data-error="nome" hidden></span>
  </div>

  <div class="form-group">
    <label for="contacto">Telefone ou email <span aria-hidden="true">*</span></label>
    <input
      type="text"
      id="contacto"
      name="contacto"
      placeholder="Número ou endereço de email"
      aria-invalid="false"
      data-field="contacto"
    />
    <span id="erro-contacto" class="form-erro" role="alert" data-error="contacto" hidden></span>
  </div>

  <div class="form-group">
    <label for="formato">Formato de interesse</label>
    <select id="formato" name="formato" data-field="formato">
      <option value="" disabled selected>Seleccione uma opção</option>
      <option value="presencial">Presencial no estúdio</option>
      <option value="online">Online por videochamada</option>
      <option value="app">Plano por app</option>
      <option value="outdoor">Treino outdoor</option>
      <option value="empresas">Ginástica laboral / Empresas</option>
      <option value="outro">Outro / Não sei ainda</option>
    </select>
  </div>

  <div class="form-group">
    <label for="mensagem">Mensagem</label>
    <textarea
      id="mensagem"
      name="mensagem"
      rows="4"
      placeholder="Conte brevemente o que procura..."
      data-field="mensagem"
    ></textarea>
  </div>

  <button type="submit" class="btn btn--primary btn--full">Enviar pedido</button>
</form>

<script>
  const FORMSPREE_ENDPOINT = '';

  const validateContact = (nome, contacto) => {
    const errors = {};
    const trimmedContact = contacto.trim();

    if (!nome.trim()) errors.nome = 'Por favor, introduza o seu nome.';
    if (!trimmedContact) errors.contacto = 'Por favor, introduza telefone ou email.';
    else if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(trimmedContact) && !/^[\d\s+\-()]{7,}$/.test(trimmedContact)) {
      errors.contacto = 'Introduza um email ou número de telefone válido.';
    }

    return errors;
  };

  document.querySelectorAll('[data-contact-form]').forEach((form) => {
    const submitButton = form.querySelector('button[type="submit"]');
    const fields = {
      nome: form.querySelector('[data-field="nome"]'),
      contacto: form.querySelector('[data-field="contacto"]'),
      formato: form.querySelector('[data-field="formato"]'),
      mensagem: form.querySelector('[data-field="mensagem"]'),
    };
    const errorEls = {
      nome: form.querySelector('[data-error="nome"]'),
      contacto: form.querySelector('[data-error="contacto"]'),
    };

    const setErrors = (errors) => {
      ['nome', 'contacto'].forEach((key) => {
        const hasError = Boolean(errors[key]);
        fields[key].setAttribute('aria-invalid', String(hasError));
        if (hasError) fields[key].setAttribute('aria-describedby', `erro-${key}`);
        else fields[key].removeAttribute('aria-describedby');
        errorEls[key].hidden = !hasError;
        errorEls[key].textContent = errors[key] || '';
      });
    };

    const showSuccess = () => {
      form.outerHTML = `
        <div class="form-sucesso" role="alert">
          <strong>✓ Pedido enviado!</strong>
          <p>Entraremos em contacto nas próximas 24 horas.</p>
        </div>
      `;
    };

    form.addEventListener('submit', async (event) => {
      event.preventDefault();

      const errors = validateContact(fields.nome.value, fields.contacto.value);
      setErrors(errors);
      if (Object.keys(errors).length) return;

      submitButton.disabled = true;
      submitButton.textContent = 'A enviar...';

      const payload = {
        nome: fields.nome.value,
        contacto: fields.contacto.value,
        formato: fields.formato.value,
        mensagem: fields.mensagem.value,
      };

      if (FORMSPREE_ENDPOINT) {
        try {
          const response = await fetch(FORMSPREE_ENDPOINT, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
            body: JSON.stringify(payload),
          });
          if (!response.ok) throw new Error('Form request failed');
          showSuccess();
        } catch {
          alert('Não foi possível enviar. Por favor contacte pelo WhatsApp.');
          submitButton.disabled = false;
          submitButton.textContent = 'Enviar pedido';
        }
        return;
      }

      await new Promise((resolve) => window.setTimeout(resolve, 300));
      console.info('[DEMO] Dados sem envio real:', payload);
      showSuccess();
    });
  });
</script>
