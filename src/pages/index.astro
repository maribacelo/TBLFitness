---
// src/pages/index.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Quiz from '../components/Quiz.astro';
import ContactForm from '../components/ContactForm.astro';
import OptimizedImage from '../components/OptimizedImage.astro';
import '../styles/global.css';

const assetBase = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const imagePath = (file: string) => `${assetBase}images/${file}`;

const imageMeta = {
  fotoSessao1: { src: imagePath('foto_sessao_1.jpg'), width: 900, height: 1200 },
  fotoBernardo: { src: imagePath('foto_bernardo.jpg'), width: 600, height: 631 },
  fotoEspaco1: { src: imagePath('foto_espaco_1.jpg'), width: 900, height: 1200 },
  fotoEspaco2: { src: imagePath('foto_espaco_2.jpg'), width: 900, height: 1200 },
  fotoSessao2: { src: imagePath('foto_sessao_2.jpg'), width: 900, height: 1200 },
  fotoMapa: { src: imagePath('foto_mapa.jpg'), width: 692, height: 600 },
};
---

<BaseLayout>
  <Header />

  <main id="main-content">

    <!-- ═══════════════════════════════ HERO ═══════════════════════════════ -->
    <section class="hero" id="inicio" aria-label="Apresentação">
      <div class="container hero__inner">
        <div class="hero__content">
          <p class="hero__eyebrow section-label">Personal Trainer · Areeiro · Lisboa</p>
          <h1 class="hero__title">
            Treinar melhor,<br>
            <em>para viver melhor.</em>
          </h1>
          <p class="hero__subtitle">
            Acompanhamento individual em Lisboa — presencial no Areeiro, por videochamada ou por app.
            Com foco em força, mobilidade e qualidade de vida real.
          </p>
          <div class="hero__tags">
            <span>"Não sei por onde começar."</span>
            <span>"Tenho receio de me magoar."</span>
            <span>"Cansado de ginásios impessoais."</span>
            <span>"Quero mais força e energia."</span>
          </div>
          <div class="hero__actions">
            <a href="https://wa.me/351969698944?text=Ol%C3%A1%20Bernardo%2C%20gostaria%20de%20marcar%20uma%20avalia%C3%A7%C3%A3o%20inicial." target="_blank" rel="noopener noreferrer" class="btn btn--primary btn--large">
              Agendar avaliação inicial
            </a>
            <a href="https://wa.me/351969698944" target="_blank" rel="noopener noreferrer" class="btn btn--wa btn--large">
              💬 Falar pelo WhatsApp
            </a>
          </div>
          <p class="hero__note">Sem compromisso. A avaliação inicial é o primeiro passo.</p>
        </div>
        <div class="hero__visual">
          <div class="hero__img-wrap">
            <OptimizedImage src={imageMeta.fotoSessao1.src} alt="Bernardo a acompanhar sessão de treino personalizado no Areeiro" width={imageMeta.fotoSessao1.width} height={imageMeta.fotoSessao1.height} loading="eager" fetchpriority="high" />
            <div class="hero__badge">
              <span>Areeiro, Lisboa</span>
              <small>Estúdio privado · Online · App</small>
            </div>
          </div>
        </div>
      </div>

      <!-- Barra de confiança -->
      <div class="container">
        <div class="trust-bar">
          <div class="trust-item"><strong>1:1</strong><span>Acompanhamento individual</span></div>
          <div class="trust-item"><strong>1h</strong><span>Sessões completas sempre</span></div>
          <div class="trust-item"><strong>5</strong><span>Formatos disponíveis</span></div>
          <div class="trust-item"><strong>📍</strong><span>Areeiro · Online · Empresas</span></div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════ IDENTIFICAÇÃO ═══════════════════════════ -->
    <section class="identificacao" id="identificacao" aria-labelledby="id-titulo">
      <div class="container">
        <div class="identificacao__inner">
          <div class="identificacao__texto">
            <p class="section-label">Reconhece-se?</p>
            <h2 id="id-titulo">Este acompanhamento pode ser para si.</h2>
            <div class="divider"></div>
            <p>Cada pessoa chega com uma história diferente. O ponto em comum é a necessidade de um treino mais consciente, acompanhado e ajustado à realidade de cada um.</p>
            <a href="https://wa.me/351969698944?text=Ol%C3%A1%20Bernardo%2C%20gostaria%20de%20perceber%20o%20melhor%20plano%20para%20mim." target="_blank" rel="noopener noreferrer" class="btn btn--primary">
              Perceber o melhor plano
            </a>
          </div>
          <div class="identificacao__cards">
            {[
              { icon: '🏟️', t: 'Cansado de ginásios cheios',       d: 'Impessoais, sem orientação, sem acompanhamento. Aqui é diferente.' },
              { icon: '🤷', t: 'Não sabe por onde começar',         d: 'A avaliação inicial serve exactamente para isso. Sem pressão.' },
              { icon: '⚠️', t: 'Receio de se magoar',               d: 'A técnica é sempre corrigida e o ritmo respeitado.' },
              { icon: '📋', t: 'Já tentou, mas sem consistência',   d: 'Faltou estrutura, orientação e acompanhamento ao longo do tempo.' },
              { icon: '🎯', t: 'Quer um treino adaptado a si',      d: 'Ao seu corpo, rotina, limitações e objectivos reais.' },
              { icon: '🌿', t: 'Numa fase específica da vida',      d: 'Gravidez, pós-parto, regresso após lesão, idade sénior.' },
            ].map(c => (
              <div class="id-card fade-in">
                <span>{c.icon}</span>
                <div><strong>{c.t}</strong><p>{c.d}</p></div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════ FORMATOS ═══════════════════════════ -->
    <section class="formatos" id="formatos" aria-labelledby="fmt-titulo">
      <div class="container">
        <p class="section-label">Como trabalhamos</p>
        <h2 id="fmt-titulo">Formatos de treino</h2>
        <p class="section-intro">Cinco formas de trabalhar, cada uma pensada para um contexto diferente. Em todas as sessões com o Bernardo, uma hora completa.</p>

        <div class="formatos__grid">
          {[
            {
              id: 's-presencial',
              img: imagePath('foto_sessao_4.jpg'),
              width: 900,
              height: 1200,
              alt: 'Sessão de personal training presencial no estúdio do Areeiro',
              badge: 'Individual ou dupla', badgeCor: '#4A7A2E',
              tag: 'No estúdio', emoji: '🏋️',
              titulo: 'Personal Training Presencial',
              desc: 'Sessões de 1 hora no estúdio privado do Areeiro. Individual ou em dupla — casal, amigos ou colegas.',
              wa: 'Ol%C3%A1%20Bernardo%2C%20gostaria%20de%20saber%20mais%20sobre%20o%20treino%20presencial.',
            },
            {
              id: 's-online',
              img: imagePath('foto_online.jpg'),
              width: 1000,
              height: 1221,
              alt: 'Sessão de personal training online por videochamada',
              badge: 'Sem deslocação', badgeCor: '#1971C2',
              tag: 'Videochamada', emoji: '💻',
              titulo: 'Personal Training Online',
              desc: 'Treino ao vivo por videochamada, 1 hora completa. Mesma estrutura do presencial, sem necessidade de deslocação.',
              wa: 'Ol%C3%A1%20Bernardo%2C%20gostaria%20de%20saber%20mais%20sobre%20o%20treino%20online.',
            },
            {
              id: 's-app',
              img: imagePath('foto_app.jpg'),
              width: 533,
              height: 800,
              alt: 'App de treino personalizado com plano e vídeos',
              badge: 'Mais acessível', badgeCor: '#2F9E44',
              tag: 'App + WhatsApp', emoji: '📱',
              titulo: 'Plano por App',
              desc: 'Plano mensal personalizado com vídeos explicativos. Treina no teu horário com acompanhamento por WhatsApp.',
              wa: 'Ol%C3%A1%20Bernardo%2C%20gostaria%20de%20saber%20mais%20sobre%20o%20plano%20por%20app.',
            },
            {
              id: 's-outdoor',
              img: imagePath('foto_outdoor.jpg'),
              width: 1000,
              height: 1258,
              alt: 'Treino outdoor num parque de Lisboa',
              badge: 'Individual ou grupo', badgeCor: '#E8590C',
              tag: 'Ao ar livre', emoji: '🌿',
              titulo: 'Treino Outdoor',
              desc: 'Sessões em espaços exteriores de Lisboa — individual ou em pequenos grupos. Mesmo nível de acompanhamento.',
              wa: 'Ol%C3%A1%20Bernardo%2C%20gostaria%20de%20saber%20mais%20sobre%20o%20treino%20outdoor.',
            },
            {
              id: 's-laboral',
              img: imagePath('foto_laboral.jpg'),
              width: 1000,
              height: 750,
              alt: 'Ginástica laboral em empresa com grupo de colaboradores',
              badge: 'Para empresas', badgeCor: '#2F4A35',
              tag: 'Empresas', emoji: '🏢',
              titulo: 'Ginástica Laboral',
              desc: 'O Bernardo desloca-se às empresas. HIIT, mobilidade e activação em grupo. Clientes: Galp, Cofidis, Solinca, Time to Fitness, Pavilhão Municipal Casal Vistoso.',
              wa: 'Ol%C3%A1%20Bernardo%2C%20gostaria%20de%20saber%20mais%20sobre%20gin%C3%A1stica%20laboral.',
            },
          ].map(f => (
            <article class="formato-card fade-in" id={f.id}>
              <div class="formato-card__img">
                <OptimizedImage src={f.img} alt={f.alt} width={f.width} height={f.height} />
                <span class="formato-badge" style={`background:${f.badgeCor}`}>{f.badge}</span>
                <span class="formato-tag">{f.tag}</span>
              </div>
              <div class="formato-card__body">
                <h3>{f.emoji} {f.titulo}</h3>
                <p>{f.desc}</p>
                <a href={`https://wa.me/351969698944?text=${f.wa}`} target="_blank" rel="noopener noreferrer" class="formato-cta">
                  Saber mais →
                </a>
              </div>
            </article>
          ))}
        </div>

        <!-- Avaliação CTA -->
        <div class="avaliacao-cta">
          <div>
            <p class="section-label section-label--light">Primeiro passo</p>
            <h3>Avaliação inicial</h3>
            <p>Uma sessão para perceber o seu ponto de partida. Não precisa de saber o que quer — a avaliação serve para isso. Sem compromisso imediato.</p>
          </div>
          <a href="https://wa.me/351969698944?text=Ol%C3%A1%20Bernardo%2C%20gostaria%20de%20marcar%20uma%20avalia%C3%A7%C3%A3o%20inicial." target="_blank" rel="noopener noreferrer" class="btn btn--white btn--large">
            Marcar avaliação inicial
          </a>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════ QUIZ ═══════════════════════ -->
    <section class="quiz-section" id="quiz" aria-labelledby="quiz-titulo">
      <div class="container">
        <div class="quiz-section__header">
          <p class="section-label">Encontre o seu formato</p>
          <h2 id="quiz-titulo">Qual o melhor formato para si?</h2>
          <p>Responda a algumas perguntas — leva menos de 1 minuto.</p>
        </div>
        <div class="quiz-section__card">
          <Quiz />
        </div>
      </div>
    </section>

    <!-- ═══════════════════════ ESPECIALIDADES ═══════════════════════════ -->
    <section class="especialidades" id="especialidades" aria-labelledby="esp-titulo">
      <div class="container">
        <p class="section-label">Especialidades</p>
        <h2 id="esp-titulo">Focos de trabalho</h2>
        <p class="section-intro">O acompanhamento adapta-se ao objectivo e à fase da vida de cada pessoa.</p>
        <div class="esp__grid">
          {[
            {
              icon: '💪', titulo: 'Força e hipertrofia',
              desc: 'Ganho de massa muscular e força para saúde, postura e qualidade de vida. Programação baseada em sobrecarga progressiva e padrões fundamentais de movimento.',
              detalhes: 'Sobrecarga progressiva, periodização e recuperação. Padrões: agachar, empurrar, puxar, transportar. Adaptado ao nível e histórico de cada pessoa.',
              para: 'Adultos que querem ganhar massa muscular de forma saudável ou simplesmente sentir-se mais fortes.',
              tags: ['Sobrecarga progressiva','Hipertrofia','Força funcional'],
              wa: 'treino%20de%20for%C3%A7a',
            },
            {
              icon: '🤍', titulo: 'Treino sénior',
              desc: 'Força funcional, equilíbrio, coordenação e mobilidade articular. Exercícios que replicam movimentos do quotidiano com progressão cuidadosa.',
              detalhes: 'Levantamentos funcionais, equilíbrio, prevenção de quedas. Ritmo sempre respeitado, atenção a condições de saúde.',
              para: 'Adultos a partir dos 60 anos que querem manter autonomia, mobilidade e qualidade de vida.',
              tags: ['Força funcional','Equilíbrio','Autonomia','Prevenção de quedas'],
              wa: 'treino%20s%C3%A9nior',
            },
            {
              icon: '🌸', titulo: 'Grávidas e pós-parto',
              desc: 'Exercício adaptado à gravidez e ao pós-parto — pavimento pélvico, pressão intra-abdominal, mobilidade e recuperação progressiva.',
              detalhes: 'Gravidez: controlo da pressão abdominal, pavimento pélvico, postura. Pós-parto: reabilitação do core, atenção à diástase. Com indicação médica quando aplicável.',
              para: 'Grávidas em qualquer trimestre e mulheres no pós-parto.',
              tags: ['Pavimento pélvico','Diástase','Reabilitação pós-parto'],
              wa: 'treino%20para%20gr%C3%A1vidas',
            },
            {
              icon: '🔄', titulo: 'Recuperação e reabilitação',
              desc: 'Para pessoas em recuperação de lesões, cirurgias ou condições neurológicas como AVC. O treino complementa a fisioterapia com ganho progressivo de força.',
              detalhes: 'Padrões de movimento adaptados, progressão gradual, atenção à compensação. Comunicação com equipa médica quando necessário.',
              para: 'Pessoas em recuperação de lesões, pós-cirurgia, AVC ou com limitações físicas.',
              tags: ['Recuperação de lesões','Pós-AVC','Força progressiva'],
              wa: 'recupera%C3%A7%C3%A3o%20e%20reabilita%C3%A7%C3%A3o',
            },
          ].map(e => (
            <article class="esp-card fade-in">
              <div class="esp-card__icon">{e.icon}</div>
              <h3>{e.titulo}</h3>
              <p>{e.desc}</p>
              <div class="esp-tags">
                {e.tags.map(t => <span>{t}</span>)}
              </div>
              <details class="esp-card__details">
                <summary>Como se trabalha</summary>
                <div>
                  <p>{e.detalhes}</p>
                  <div class="esp-card__para">
                    <strong>Ideal para</strong>
                    <p>{e.para}</p>
                  </div>
                  <a href={`https://wa.me/351969698944?text=Ol%C3%A1%20Bernardo%2C%20gostaria%20de%20saber%20mais%20sobre%20${e.wa}.`} target="_blank" rel="noopener noreferrer" class="btn btn--primary btn--full">
                    Saber mais
                  </a>
                </div>
              </details>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══════════════════════ AVALIAÇÃO TÉCNICA ═══════════════════════ -->
    <section class="avaliacao" id="avaliacao" aria-labelledby="av-titulo">
      <div class="container">
        <div class="avaliacao__inner">
          <div class="avaliacao__intro">
            <p class="section-label">Avaliação inicial</p>
            <h2 id="av-titulo">O que acontece na primeira sessão.</h2>
            <div class="divider"></div>
            <p>A avaliação não é um formulário. É uma sessão de observação real que permite construir um ponto de partida honesto e um plano que faz sentido para aquela pessoa específica.</p>
            <div class="avaliacao__duracao">
              <strong>Duração</strong><span>60 a 75 minutos</span>
            </div>
            <a href="https://wa.me/351969698944?text=Ol%C3%A1%20Bernardo%2C%20gostaria%20de%20marcar%20uma%20avalia%C3%A7%C3%A3o%20inicial." target="_blank" rel="noopener noreferrer" class="btn btn--primary">
              Marcar avaliação
            </a>
          </div>
          <ol class="avaliacao__fases">
            {[
              { n:'01', t:'Conversa inicial', d:'Histórico, lesões, patologias, rotina, disponibilidade e objectivos. Contexto real antes de qualquer avaliação física.', active: true },
              { n:'02', t:'Análise postural e padrões de movimento', d:'Observação de postura e padrões fundamentais — agachar, empurrar, puxar, rodar. Identificação de desequilíbrios.' },
              { n:'03', t:'Avaliação de mobilidade articular', d:'Testes de mobilidade — anca, ombros, coluna torácica, tornozelos. Define o que trabalhar imediatamente.' },
              { n:'04', t:'Testes de força e capacidade física', d:'Testes funcionais adaptados ao nível real de cada pessoa. Sem comparações normativas.' },
              { n:'05', t:'Definição do plano', d:'Frequência, tipo de treino, foco inicial e metas realistas. O plano é explicado, não apenas entregue.' },
            ].map(f => (
              <li>
                <span class={`fase-num${f.active ? ' active' : ''}`}>{f.n}</span>
                <div><h3>{f.t}</h3><p>{f.d}</p></div>
              </li>
            ))}
          </ol>
        </div>
      </div>
    </section>

    <!-- ══════════════════════ COMO FUNCIONA ══════════════════════════════ -->
    <section class="como-funciona" id="como-funciona" aria-labelledby="cf-titulo">
      <div class="container">
        <p class="section-label">O processo</p>
        <h2 id="cf-titulo">Como funciona.</h2>
        <p class="section-intro">Simples e directo. A partir da avaliação, tudo tem uma razão de ser.</p>
        <ol class="passos">
          {[
            { n:'01', t:'Avaliação inicial', d:'Perceber o ponto de partida — mobilidade, força, padrões de movimento, histórico e objectivos.', active: true },
            { n:'02', t:'Plano personalizado', d:'Abordagem construída para si, explicada antes de começar. Frequência, tipo de treino e progressão.' },
            { n:'03', t:'Sessões acompanhadas', d:'Cada sessão tem orientação directa — execução corrigida, carga ajustada, técnica supervisionada.' },
            { n:'04', t:'Progressão e ajustes', d:'O plano evolui com a pessoa. Avaliações regulares e adaptação a qualquer mudança.' },
          ].map(p => (
            <li class="passo fade-in">
              <span class={`passo__num${p.active ? ' active' : ''}`}>{p.n}</span>
              <div><h3>{p.t}</h3><p>{p.d}</p></div>
            </li>
          ))}
        </ol>
        <a href="https://wa.me/351969698944?text=Ol%C3%A1%20Bernardo%2C%20gostaria%20de%20come%C3%A7ar%20com%20uma%20avalia%C3%A7%C3%A3o." target="_blank" rel="noopener noreferrer" class="btn btn--primary">
          Começar com uma avaliação
        </a>
        <p class="passos__nota">Resposta em menos de 24h.</p>
      </div>
    </section>

    <!-- ════════════════════════ SOBRE ═══════════════════════════════════ -->
    <section class="sobre" id="sobre" aria-labelledby="sb-titulo">
      <div class="container sobre__inner">
        <div class="sobre__visual">
          <OptimizedImage src={imageMeta.fotoBernardo.src} alt="Bernardo Lima, personal trainer no Areeiro, Lisboa" width={imageMeta.fotoBernardo.width} height={imageMeta.fotoBernardo.height} />
          <div class="sobre__stats">
            <div class="stat"><strong>13+</strong><span>Anos de experiência</span></div>
            <div class="stat"><strong>+100</strong><span>Clientes acompanhados</span></div>
          </div>
        </div>
        <div class="sobre__conteudo">
          <p class="section-label">Sobre</p>
          <h2 id="sb-titulo">O Bernardo</h2>
          <div class="divider"></div>
          <p>O Bernardo trabalha com pessoas que procuram treinar de forma mais consciente, segura e personalizada. O foco está em adaptar o treino à realidade de cada cliente — respeitando o ponto de partida, os objectivos, as limitações e a rotina.</p>
          <p>Acredita que o exercício físico deve ser uma ferramenta ao serviço do bem-estar — não uma pressão estética, não uma competição. O treino deve fazer sentido para quem o faz.</p>
          <p>Ao longo do percurso acompanhou pessoas muito diferentes: desde quem começa do zero, quem regressa após lesão, grávidas, adultos seniores, pessoas em recuperação neurológica, até quem simplesmente quer sentir-se mais capaz no dia-a-dia.</p>
          <div class="sobre__formacao">
            <strong>Formação</strong>
            <ul><li>Licenciatura em Educação Física e Desporto — Universidade Lusófona</li></ul>
          </div>
          <div class="sobre__empresas">
            <strong>Experiência com empresas e espaços</strong>
            <div class="empresas-tags">
              <span>Galp</span><span>Cofidis</span><span>Solinca</span><span>Time to Fitness</span><span>Pavilhão Municipal Casal Vistoso</span>
            </div>
          </div>
          <a href="https://wa.me/351969698944" target="_blank" rel="noopener noreferrer" class="btn btn--outline">
            Falar com o Bernardo
          </a>
        </div>
      </div>
    </section>

    <!-- ════════════════════════ TESTEMUNHOS ═════════════════════════════ -->
    <section class="testemunhos" id="testemunhos" aria-labelledby="t-titulo">
      <div class="container">
        <p class="section-label">O que dizem</p>
        <h2 id="t-titulo">Testemunhos</h2>
        <div class="testemunhos__grid">
          {[
            { av: imagePath('avatar_raquel.jpg'), nome:'Raquel Montez',   fmt:'Presencial', foco:'Força e mobilidade',  cor:'#4A7A2E',
              texto:'"Treino 1x por semana com o Bernardo desde setembro de 2024 e os resultados no meu bem-estar são notórios. Antes passava a vida a remediar dores de costas com massagens. Desde então não só me sinto mais forte, como sem dores e mais motivada."',
              resultado:'Dores de costas (escoliose) eliminadas após 1 ano e 5 meses' },
            { av: imagePath('avatar_jose.jpg'),   nome:'Jose Laureano',   fmt:'Presencial', foco:'Treino sénior',       cor:'#4A7A2E',
              texto:'"Tenho mais de 50 anos e problemas crónicos de costas. Desde que comecei a treinar com o Bernardo, especialmente com os treinos de mobilidade, tenho-me sentido muito melhor no dia a dia."',
              resultado:'Melhoria significativa com treinos de mobilidade adaptados' },
            { av: imagePath('avatar_ines.jpg'),   nome:'Inês Rodrigues',  fmt:'Presencial', foco:'Grávidas e pós-parto', cor:'#4A7A2E',
              texto:'"O Bernardo é um excelente profissional, com muito conhecimento técnico. Foi muito importante na minha gravidez e também me acompanhou no processo pós-parto, sempre disponível e respeitando o meu timing."',
              resultado:'Acompanhamento completo da gravidez ao pós-parto' },
            { av: imagePath('avatar_tania.jpg'),  nome:'Tânia Ramos',     fmt:'Presencial', foco:'Reabilitação',        cor:'#4A7A2E',
