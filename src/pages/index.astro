.passo__num { width: 3rem; height: 3rem; border-radius: var(--radius-full); background: #fff; border: 2px solid var(--borda); display: flex; align-items: center; justify-content: center; font-family: var(--serif); font-size: 1.125rem; color: var(--verde); flex-shrink: 0; }
